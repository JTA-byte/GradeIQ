# Anthropic API key -- required for AI vision card analysis.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase project URL and public anon key -- required for auth and
# database features (safe to expose in the browser; row-level security
# policies in supabase/schema.sql restrict access).
# Found in Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key -- NOT the public anon key.
# Found in Supabase project settings -> API -> service_role secret.
# This bypasses row-level security, so keep it server-side only --
# never expose it in the Next.js frontend or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=
