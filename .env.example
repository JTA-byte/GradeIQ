# Anthropic API key -- required for AI vision card analysis.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase project URL and public anon key -- required for auth and
# database features (safe to expose in the browser; row-level security
# policies in supabase/schema.sql restrict access).
# Found in Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key -- NOT the public anon key.
# Found in Supabase project settings -> API -> service_role secret.
# This bypasses row-level security, so keep it server-side only --
# never expose it in the Next.js frontend or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe -- required for Pro subscriptions ($12/month).
# Get STRIPE_SECRET_KEY and NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY from
# Stripe Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# STRIPE_PRO_PRICE_ID -- the Price ID of the Pro plan's recurring price
# (Stripe Dashboard -> Product catalog -> your Pro product -> price).
STRIPE_PRO_PRICE_ID=

# STRIPE_WEBHOOK_SECRET -- from Stripe Dashboard -> Developers -> Webhooks
# -> your endpoint -> "Signing secret".
STRIPE_WEBHOOK_SECRET=

# TCGPlayer -- optional, powers real raw market pricing in lib/tcgplayer.ts.
# Apply for API access at docs.tcgplayer.com (approval can take a few days).
# TCGPLAYER_API_KEY is your public key (client_id), TCGPLAYER_API_SECRET is
# your private key (client_secret). Leave both blank to use mock pricing --
# note TCGPlayer has no graded-card pricing regardless, see lib/tcgplayer.ts.
TCGPLAYER_API_KEY=
TCGPLAYER_API_SECRET=
